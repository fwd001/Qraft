<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="gen_qr"
        android:shortcutShortLabel="@string/shortcut_generate"
        android:shortcutLongLabel="@string/shortcut_generate_long"
        android:icon="@drawable/ic_shortcut_generate">
        <intent
            android:action="android.intent.action.MAIN"
            android:targetPackage="com.qrcodekit.app"
            android:targetClass="com.qrcodekit.app.ui.MainActivity">
            <extra android:name="target_tab" android:value="generate" />
        </intent>
    </shortcut>
    <shortcut
        android:shortcutId="scan_qr"
        android:shortcutShortLabel="@string/shortcut_scan"
        android:shortcutLongLabel="@string/shortcut_scan_long"
        android:icon="@drawable/ic_shortcut_scan">
        <intent
            android:action="android.intent.action.MAIN"
            android:targetPackage="com.qrcodekit.app"
            android:targetClass="com.qrcodekit.app.ui.MainActivity">
            <extra android:name="target_tab" android:value="scan" />
        </intent>
    </shortcut>
</shortcuts>
